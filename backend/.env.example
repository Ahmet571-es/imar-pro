# imarPRO Backend Environment Variables
# Railway: Settings → Variables

# AI API Keys (frontend Settings'ten de girilebilir)
ANTHROPIC_API_KEY=
XAI_API_KEY=

# Custom domain CORS (opsiyonel, örn: https://imarpro.com)
CORS_ORIGIN=

# Supabase (opsiyonel — backend tarafında şu an kullanılmıyor)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
